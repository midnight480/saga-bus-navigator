{
  "name": "saga-bus-navigator",
  "version": "1.0.0",
  "description": "佐賀市内バスナビゲーションアプリ",
  "scripts": {
    "dev": "http-server . -p 8080",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint js/**/*.js",
    "format": "prettier --write js/**/*.js",
    "build": "cd functions && npm install"
  },
  "keywords": [
    "bus",
    "navigation",
    "saga",
    "japan"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "gtfs-realtime-bindings": "^1.1.0",
    "protobufjs": "^7.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "eslint": "^8.0.0",
    "fast-check": "^4.3.0",
    "http-server": "^14.0.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.0.0",
    "vitest": "^1.0.0"
  }
}
