/*
  # セキュリティヘッダー設定（Cloudflare Pages用）
  
  # Content Security Policy (CSP)
  # - default-src 'self': デフォルトは同一オリジンのみ
  # - script-src 'self' https://static.cloudflareinsights.com: スクリプトは同一オリジン + Cloudflare Insights（アクセス解析）
  # - style-src 'self' 'unsafe-inline': スタイルは同一オリジン + インラインCSS許可
  # - img-src 'self' data: https://*.tile.openstreetmap.org https://*.tile.openstreetmap.fr: 画像は同一オリジン + data:スキーム + OpenStreetMap地図タイル（負荷分散用サブドメイン a, b, c を含む）
  # - connect-src 'self' https://ntp-a1.nict.go.jp https://holidays-jp.github.io http://opendata.sagabus.info: 外部API接続許可（GTFS-Realtimeデータ取得用）
  # - font-src 'self': フォントは同一オリジンのみ
  # - object-src 'none': Flash等のプラグイン禁止
  # - base-uri 'self': base要素は同一オリジンのみ
  # - form-action 'self': フォーム送信は同一オリジンのみ
  # - frame-ancestors 'none': iframe埋め込み禁止
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.tile.openstreetmap.org https://*.tile.openstreetmap.fr; connect-src 'self' https://ntp-a1.nict.go.jp https://holidays-jp.github.io http://opendata.sagabus.info; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';
  
  # X-Frame-Options: iframe埋め込み禁止（クリックジャッキング対策）
  X-Frame-Options: DENY
  
  # X-Content-Type-Options: MIMEタイプスニッフィング防止
  X-Content-Type-Options: nosniff
  
  # Referrer-Policy: リファラー情報の送信を制限
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions-Policy: 不要な機能を無効化（位置情報は同一オリジンでのみ許可）
  Permissions-Policy: geolocation=(self), microphone=(), camera=()
